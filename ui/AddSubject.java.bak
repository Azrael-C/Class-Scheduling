        txtSubjectName.setFont(new Font("Bricolage Grotesque", Font.PLAIN, 30));
        txtSubjectName.setColumns(10);
        txtSubjectName.setBounds(410, 163, 696, 43);
        panel_1.add(txtSubjectName);

