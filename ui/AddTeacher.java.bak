    /**
     * Create the frame.
     */
    public AddTeacher() {
        // === Load Poppins Fonts ===
        try {
            poppinsRegular = Font.createFont(Font.TRUETYPE_FONT, new File("src/fonts/Poppins-Regular.ttf")).deriveFont(22f);
            poppinsMedium = Font.createFont(Font.TRUETYPE_FONT, new File("src/fonts/Poppins-Medium.ttf")).deriveFont(26f);
            poppinsBold = Font.createFont(Font.TRUETYPE_FONT, new File("src/fonts/Poppins-Bold.ttf")).deriveFont(60f);
            GraphicsEnvironment ge = GraphicsEnvironment.getLocalGraphicsEnvironment();
            ge.registerFont(poppinsRegular);
            ge.registerFont(poppinsMedium);
            ge.registerFont(poppinsBold);
        } catch (Exception e) {
            System.out.println("Font loading failed, using default fonts.");
            poppinsRegular = new Font("SansSerif", Font.PLAIN, 22);
            poppinsMedium = new Font("SansSerif", Font.BOLD, 26);
            poppinsBold = new Font("SansSerif", Font.BOLD, 60);
        }

        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setExtendedState(JFrame.MAXIMIZED_BOTH); // full screen
        contentPane = new JPanel(null);
        contentPane.setBorder(new EmptyBorder(5, 5, 5, 5));
        setContentPane(contentPane);

        // Blue background
        JPanel panel = new JPanel(null);
        panel.setBackground(new Color(26, 35, 126));
        panel.setBounds(0, 0, 1920, 1080); // Initial guess, will be resized
        contentPane.add(panel);

        // White container (centered, proportional)
        int panelWidth = (int) (1920 * 0.8);
        int panelHeight = (int) (1080 * 0.85);
        int panelX = (1920 - panelWidth) / 2;
        int panelY = (1080 - panelHeight) / 2;

        JPanel panel_1 = new JPanel(null);
        panel_1.setBackground(Color.WHITE);
        panel_1.setBounds(panelX, panelY, panelWidth, panelHeight);
        panel.add(panel_1);
        
        // Title label centered
        int titleWidth = 600;
        int titleX = (panelWidth - titleWidth) / 2;
        JLabel lblAddTeacher = new JLabel("Add Teacher");
        lblAddTeacher.setHorizontalAlignment(SwingConstants.CENTER);
        lblAddTeacher.setForeground(new Color(26, 35, 126));
        lblAddTeacher.setFont(poppinsBold.deriveFont(50f));
        lblAddTeacher.setBounds(titleX, 50, titleWidth, 70);
        panel_1.add(lblAddTeacher);
        
        // Labels and text fields
        int labelX = 150;
        int fieldX = 400;
        int fieldWidth = 600;
        int fieldHeight = 40;
        int gap = 60;
        int startY = 150;
        
        JLabel lblName = new JLabel("Name");
        lblName.setHorizontalAlignment(SwingConstants.LEFT);
        lblName.setForeground(new Color(26, 35, 126));
        lblName.setFont(poppinsRegular.deriveFont(25f));
        lblName.setBounds(labelX, startY, 200, 40);
        panel_1.add(lblName);
        
        textField = new JTextField();
        textField.setHorizontalAlignment(SwingConstants.LEFT);
        textField.setForeground(new Color(26, 35, 126));
        textField.setFont(poppinsRegular.deriveFont(20f));
        textField.setBounds(fieldX, startY, fieldWidth, fieldHeight);
        panel_1.add(textField);
        textField.setColumns(10);
        
        JLabel lblPosition = new JLabel("Position");
        lblPosition.setHorizontalAlignment(SwingConstants.LEFT);
        lblPosition.setForeground(new Color(26, 35, 126));
        lblPosition.setFont(poppinsRegular.deriveFont(25f));
        lblPosition.setBounds(labelX, startY + gap, 200, 40);
        panel_1.add(lblPosition);
        
        textField_1 = new JTextField();
        textField_1.setHorizontalAlignment(SwingConstants.LEFT);
        textField_1.setForeground(new Color(26, 35, 126));
        textField_1.setFont(poppinsRegular.deriveFont(20f));
        textField_1.setBounds(fieldX, startY + gap, fieldWidth, fieldHeight);
        panel_1.add(textField_1);
        textField_1.setColumns(10);
        
        JLabel lblSubjectHandled = new JLabel("Subject Handled");
        lblSubjectHandled.setHorizontalAlignment(SwingConstants.LEFT);
        lblSubjectHandled.setForeground(new Color(26, 35, 126));
        lblSubjectHandled.setFont(poppinsRegular.deriveFont(25f));
        lblSubjectHandled.setBounds(labelX, startY + 2 * gap, 250, 40);
        panel_1.add(lblSubjectHandled);
        
        textField_2 = new JTextField();
        textField_2.setHorizontalAlignment(SwingConstants.LEFT);
        textField_2.setForeground(new Color(26, 35, 126));
        textField_2.setFont(poppinsRegular.deriveFont(20f));
        textField_2.setBounds(fieldX, startY + 2 * gap, fieldWidth, fieldHeight);
        panel_1.add(textField_2);
        textField_2.setColumns(10);
        
        JLabel lblDepartment = new JLabel("Department");
        lblDepartment.setHorizontalAlignment(SwingConstants.LEFT);
        lblDepartment.setForeground(new Color(26, 35, 126));
        lblDepartment.setFont(poppinsRegular.deriveFont(25f));
        lblDepartment.setBounds(labelX, startY + 3 * gap, 200, 40);
        panel_1.add(lblDepartment);
        
        textField_3 = new JTextField();
        textField_3.setHorizontalAlignment(SwingConstants.LEFT);
        textField_3.setForeground(new Color(26, 35, 126));
        textField_3.setFont(poppinsRegular.deriveFont(20f));
        textField_3.setBounds(fieldX, startY + 3 * gap, fieldWidth, fieldHeight);
        panel_1.add(textField_3);
        textField_3.setColumns(10);
        
        JLabel lblCollege = new JLabel("College");
        lblCollege.setHorizontalAlignment(SwingConstants.LEFT);
        lblCollege.setForeground(new Color(26, 35, 126));
        lblCollege.setFont(poppinsRegular.deriveFont(25f));
        lblCollege.setBounds(labelX, startY + 4 * gap, 200, 40);
        panel_1.add(lblCollege);
        
        textField_4 = new JTextField();
        textField_4.setHorizontalAlignment(SwingConstants.LEFT);
        textField_4.setForeground(new Color(26, 35, 126));
        textField_4.setFont(poppinsRegular.deriveFont(20f));
        textField_4.setBounds(fieldX, startY + 4 * gap, fieldWidth, fieldHeight);
        panel_1.add(textField_4);
        textField_4.setColumns(10);
        
        // Buttons
        int btnWidth = 200;
        int btnHeight = 45;
        int btnY = panelHeight - 100;
        int btnGap = 50;
        int btnStartX = (panelWidth - (btnWidth * 2 + btnGap)) / 2;
        
        JButton btnBack = new JButton("Back");
        btnBack.setForeground(Color.WHITE);
        btnBack.setFont(poppinsBold.deriveFont(22f));
        btnBack.setBackground(new Color(26, 35, 126));
        btnBack.setBounds(btnStartX, btnY, btnWidth, btnHeight);
        btnBack.setFocusPainted(false);
        btnBack.setBorderPainted(false);
        panel_1.add(btnBack);
        btnBack.addActionListener(e -> {
            dispose();
            new TeacherManagement().setVisible(true);
        });
        
        JButton btnSubmit = new JButton("Submit");
        btnSubmit.setForeground(Color.WHITE);
        btnSubmit.setFont(poppinsBold.deriveFont(22f));
        btnSubmit.setBackground(new Color(26, 35, 126));
        btnSubmit.setBounds(btnStartX + btnWidth + btnGap, btnY, btnWidth, btnHeight);
        btnSubmit.setFocusPainted(false);
        btnSubmit.setBorderPainted(false);
        panel_1.add(btnSubmit);
        btnSubmit.addActionListener(e -> {
            addTeacher(); // Use this method to insert the teacher
            dispose();
            new TeacherManagement().setVisible(true);
        });

        // Dynamic resizing
        addComponentListener(new ComponentAdapter() {
            public void componentResized(ComponentEvent e) {
                int width = getWidth();
                int height = getHeight();
                panel.setBounds(0, 0, width, height);
                int panelWidth_new = (int) (width * 0.8);
                int panelHeight_new = (int) (height * 0.85);
                int panelX_new = (width - panelWidth_new) / 2;
                int panelY_new = (height - panelHeight_new) / 2;
                panel_1.setBounds(panelX_new, panelY_new, panelWidth_new, panelHeight_new);

                // Recenter title
                int titleX_new = (panelWidth_new - titleWidth) / 2;
                lblAddTeacher.setBounds(titleX_new, 50, titleWidth, 70);

                // Recenter fields
                int fieldX_new = (panelWidth_new - fieldWidth) / 2 + 100; // Adjust for labels
                textField.setBounds(fieldX_new, startY, fieldWidth, fieldHeight);
                textField_1.setBounds(fieldX_new, startY + gap, fieldWidth, fieldHeight);
                textField_2.setBounds(fieldX_new, startY + 2 * gap, fieldWidth, fieldHeight);
                textField_3.setBounds(fieldX_new, startY + 3 * gap, fieldWidth, fieldHeight);
                textField_4.setBounds(fieldX_new, startY + 4 * gap, fieldWidth, fieldHeight);

                // Recenter buttons
                int btnStartX_new = (panelWidth_new - (btnWidth * 2 + btnGap)) / 2;
                btnBack.setBounds(btnStartX_new, panelHeight_new - 100, btnWidth, btnHeight);
                btnSubmit.setBounds(btnStartX_new + btnWidth + btnGap, panelHeight_new - 100, btnWidth, btnHeight);
            }
        });
    }

    private void addTeacher() {
        String name = textField.getText().trim();
        String position = textField_1.getText().trim();
        String subjectHandled = textField_2.getText().trim();
        String department = textField_3.getText().trim();
        String college = textField_4.getText().trim();

        // Validate required fields
        if (name.isEmpty() || department.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Name and Department are required!");
            return;
        }

        try (Connection conn = DBConnection.getConnection()) {
            // Start transaction
            conn.setAutoCommit(false);

            try {
                // Step 1: Insert into accounts table
                String accountSql = "INSERT INTO accounts (username, full_email, password, role, keyword) VALUES (?, ?, ?, 'teacher', ?)";
                try (PreparedStatement accountPs = conn.prepareStatement(accountSql, PreparedStatement.RETURN_GENERATED_KEYS)) {
                    String username = name.replaceAll("\\s+", "").toLowerCase(); // Simple username
                    String email = username + "@school.com"; // Simple email
                    String password = "default123"; // Default password
                    accountPs.setString(1, username);
                    accountPs.setString(2, email);
                    accountPs.setString(3, password);
                    accountPs.setString(4, "defaultKeyword"); // Assuming 'keyword' is needed
                    accountPs.executeUpdate();

                    // Get the generated account_id
                    ResultSet rs = accountPs.getGeneratedKeys();
                    int accountId = 0;
                    if (rs.next()) {
                        accountId = rs.getInt(1);
                    }

                    // Step 2: Insert into teachers table
                    String teacherSql = "INSERT INTO teachers (account_id, full_name, department, specialization, college) VALUES (?, ?, ?, ?, ?)";
                    try (PreparedStatement teacherPs = conn.prepareStatement(teacherSql)) {
                        teacherPs.setInt(1, accountId);
                        teacherPs.setString(2, name);
                        teacherPs.setString(3, department);
                        teacherPs.setString(4, subjectHandled); // Assuming specialization is subject handled
                        teacherPs.setString(5, college);
                        teacherPs.executeUpdate();
                    }
                }

                conn.commit();
                JOptionPane.showMessageDialog(this, "Teacher added successfully!");
                clearFields();

            } catch (SQLException e) {
                conn.rollback();  // Rollback if any query fails
                e.printStackTrace();
                JOptionPane.showMessageDialog(this, "Error adding teacher: " + e.getMessage());
            } finally {
                conn.setAutoCommit(true); // Restore default auto-commit behavior
            }

        } catch (SQLException e) {
            e.printStackTrace();
            JOptionPane.showMessageDialog(this, "Database connection error: " + e.getMessage());
        }
    }

    private void clearFields() {
        textField.setText("");
        textField_1.setText("");
        textField_2.setText("");
        textField_3.setText("");
        textField_4.setText("");
    }
}