import Database.DBConnection;

public class AddTeacher extends JFrame {

    private static final long serialVersionUID = 1L;
    private JPanel contentPane;
    private JTextField textField; // Name
    private JTextField textField_1; // Position
    private JTextField textField_2; // Subject Handled
    private JTextField textField_3; // Department
